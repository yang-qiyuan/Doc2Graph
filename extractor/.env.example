# Doc2Graph Extractor - Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic Claude API Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxx...

# Claude Model Selection
# Note: If you get a 404 error, your API key may not have model access enabled
# Check https://console.anthropic.com/settings/keys for model access
# Options:
#   claude-3-haiku-20240307 (fastest, cheapest - recommended for validation)
#   claude-3-5-sonnet-20240620 (balanced)
#   claude-3-opus-20240229 (most accurate)
CLAUDE_MODEL=claude-3-haiku-20240307

# Agentic Loop Feature Flag
# Set to "true" to enable Claude-based validation, "false" to use regex-only extraction
ENABLE_AGENTIC_LOOP=false

# Maximum tokens for Claude API responses
# Default: 4096 (sufficient for validation tasks)
MAX_TOKENS=4096

# Temperature for Claude API (0.0-1.0)
# Lower = more deterministic, Higher = more creative
# Recommended: 0.0 for validation/formatting tasks
TEMPERATURE=0.0

# Proxy Configuration (optional)
# Uncomment and set these if you need to use a proxy to reach the Anthropic API
# http_proxy=http://127.0.0.1:7897
# https_proxy=http://127.0.0.1:7897
